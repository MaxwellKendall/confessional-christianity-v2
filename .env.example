# Algolia — search-only key, safe for the browser. The Admin key is used only
# by the indexing scripts (scripts/) and must never be NEXT_PUBLIC_.
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Supabase — same project as v1; live account/progress data lives here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ESV API — server-side only, used to fetch proof-text scripture for sessions.
ESV_API_KEY=
